---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../../site.config';
---

<BaseLayout
  title={`Privacy Policy - ${siteConfig.name}`}
  description={`Privacy policy for ${siteConfig.name}. How we handle your data and protect your privacy.`}
>
  <main class="page-content">
    <div class="content-wrapper">
      <h1>Privacy Policy</h1>
      <p class="updated-date">Last updated: March 2026</p>

      <section>
        <h2>Who We Are</h2>
        <p>
          Dry Climate Beauty (dryclimatebeauty.com) is an independent beauty and wellness publication. This privacy policy explains how we collect, use, and protect information when you visit our website.
        </p>
      </section>

      <section>
        <h2>Information We Collect</h2>
        <p>
          We collect minimal information. When you visit our site, standard web server logs may record your IP address, browser type, pages visited, and referring URL. If you subscribe to our newsletter, we collect your email address. We do not collect personal health information, financial data, or create user profiles for advertising purposes.
        </p>
      </section>

      <section>
        <h2>How We Use Information</h2>
        <p>
          Server logs are used to understand traffic patterns and improve site performance. Email addresses are used solely for newsletter delivery. We do not sell, trade, or share your personal information with third parties for marketing purposes.
        </p>
      </section>

      <section>
        <h2>Cookies and Tracking</h2>
        <p>
          We use essential cookies for basic site functionality. We may use analytics services to understand how visitors use the site. These services may set their own cookies. You can control cookie settings through your browser preferences.
        </p>
      </section>

      <section>
        <h2>Affiliate Links</h2>
        <p>
          Our articles contain affiliate links to product retailers. When you click these links, the retailer may set cookies to track the referral. This is standard affiliate tracking and is governed by the retailer's own privacy policy. We do not receive personally identifiable information about your purchases.
        </p>
      </section>

      <section>
        <h2>Third-Party Services</h2>
        <p>
          We may use third-party services for analytics, email delivery, and content hosting. These services have their own privacy policies. We select providers that meet reasonable data protection standards.
        </p>
      </section>

      <section>
        <h2>Data Retention</h2>
        <p>
          Server logs are retained for 90 days. Email subscription data is retained until you unsubscribe. We do not maintain permanent records of visitor browsing behavior.
        </p>
      </section>

      <section>
        <h2>Your Rights</h2>
        <p>
          You can request access to, correction of, or deletion of any personal data we hold about you. To exercise these rights, contact <strong>privacy@dryclimatebeauty.com</strong>. If you're subscribed to our newsletter, every email includes an unsubscribe link.
        </p>
      </section>

      <section>
        <h2>Changes to This Policy</h2>
        <p>
          We may update this privacy policy occasionally. Changes will be posted on this page with an updated date. We do not make material changes without notice.
        </p>
      </section>

      <section>
        <h2>Contact</h2>
        <p>
          For privacy-related questions, email <strong>privacy@dryclimatebeauty.com</strong>.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .page-content {
    padding: 2rem 0 4rem;
  }
  .content-wrapper {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .updated-date {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    margin: 2.5rem 0 1rem;
    color: var(--color-text);
  }
  p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 1.2rem;
  }
</style>