---
/**
 * "Recommended reads" with filterable category pill tabs.
 * Matches Healthline screenshot 03: pill tabs, 2-column grid of compact articles.
 * Uses Astro island for tab filtering (client:load).
 */
import { siteConfig } from '../../site.config';

interface ArticleItem {
  title: string;
  slug: string;
  category: string;
  categorySlug: string;
  heroImage: string;
  heroAlt: string;
}

interface Props {
  articles: ArticleItem[];
}

const { articles } = Astro.props;
const categories = siteConfig.categories;
const articleData = JSON.stringify(articles);
---

<section class="recommended-reads">
  <div class="container">
    <h2>Recommended reads</h2>

    <div class="tabs" data-articles={articleData}>
      <div class="tab-list" role="tablist">
        <button class="tab active" role="tab" aria-selected="true" data-category="all">Top Reads</button>
        {categories.map((cat) => (
          <button class="tab" role="tab" aria-selected="false" data-category={cat.slug}>{cat.name}</button>
        ))}
      </div>

      <div class="articles-grid" role="tabpanel">
        {articles.slice(0, 6).map((article) => (
          <article class="read-item" data-cat={article.categorySlug}>
            <a href={`/${article.categorySlug}/${article.slug}/`} class="read-thumb">
              <img
                src={article.heroImage}
                alt={article.heroAlt}
                width="100"
                height="100"
                loading="lazy"
              />
            </a>
            <h3>
              <a href={`/${article.categorySlug}/${article.slug}/`}>{article.title}</a>
            </h3>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.recommended-reads .tab');
  const items = document.querySelectorAll('.recommended-reads .read-item');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const cat = (tab as HTMLElement).dataset.category;
      items.forEach(item => {
        const el = item as HTMLElement;
        if (cat === 'all' || el.dataset.cat === cat) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .recommended-reads {
    padding: var(--space-3xl) 0;
    background: var(--color-bg);
  }

  .recommended-reads h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-bottom: var(--space-xl);
  }

  .tab-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .tab {
    padding: 0.5rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    background: transparent;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s;
  }

  .tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .tab.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg) var(--space-3xl);
  }

  .read-item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .read-thumb {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .read-thumb img {
    width: 100px;
    height: 100px;
    object-fit: cover;
  }

  .read-item h3 {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .read-item h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .read-item h3 a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }

    .tab-list {
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
    }

    .tab-list::-webkit-scrollbar {
      display: none;
    }

    .tab {
      white-space: nowrap;
    }
  }
</style>
