---
/**
 * "Explore by health topic" horizontal scroll cards.
 * Matches Healthline screenshot 02: portrait cards with category icon images,
 * category name below. Horizontally scrollable on mobile.
 */
import { siteConfig } from '../../site.config';
import categoriesData from '../data/categories.json';

const categories = siteConfig.categories.map(cat => ({
  ...cat,
  icon: categoriesData.find(c => c.slug === cat.slug)?.icon,
}));
---

<section class="category-carousel">
  <div class="container">
    <div class="carousel-header">
      <h2>Explore by health topic</h2>
    </div>
    <div class="carousel-track">
      {categories.map((cat) => (
        <a href={`/${cat.slug}/`} class="carousel-card">
          <div class="card-visual">
            {cat.icon ? (
              <img src={cat.icon} alt={cat.name} width="200" height="267" loading="lazy" class="card-img" />
            ) : (
              <span class="card-icon">{cat.name.charAt(0)}</span>
            )}
          </div>
          <span class="card-name">{cat.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .category-carousel {
    padding: var(--space-3xl) 0;
  }

  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .carousel-header h2 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin: 0;
  }

  .carousel-track {
    display: flex;
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-md);
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-card {
    flex: 0 0 calc(25% - 1.125rem);
    min-width: 200px;
    scroll-snap-align: start;
    text-decoration: none;
    text-align: center;
  }

  .card-visual {
    aspect-ratio: 3 / 4;
    border-radius: 1rem 1rem 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    transition: transform 0.3s;
    overflow: hidden;
    background: var(--color-surface);
  }

  .carousel-card:hover .card-visual {
    transform: translateY(-4px);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-icon {
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--color-primary);
    opacity: 0.3;
  }

  .card-name {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .carousel-card:hover .card-name {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .carousel-card {
      flex: 0 0 160px;
    }
  }
</style>
