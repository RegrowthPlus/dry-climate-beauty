---
/**
 * Wirecutter-variant homepage hero: three-column layout.
 * Left: "The latest" article links. Center: featured article. Right: deals sidebar.
 */
interface ArticleItem {
  title: string;
  slug: string;
  category: string;
  categorySlug: string;
  heroImage: string;
  heroAlt: string;
  description?: string;
  date?: Date;
  author?: string;
}

interface Props {
  featured: ArticleItem;
  latest: ArticleItem[];
  deals: ArticleItem[];
}

const { featured, latest, deals } = Astro.props;

const featuredHref = `/${featured.categorySlug}/${featured.slug}/`;

function formatDate(date?: Date): string {
  if (!date) return '';
  const now = new Date();
  const diff = now.getTime() - date.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (days === 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  return new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric' }).format(date);
}
---

<section class="wc-hero">
  <!-- Left: The Latest -->
  <div class="wc-latest">
    <h2 class="wc-latest-heading">The latest</h2>
    <ul class="wc-latest-list">
      {latest.map((item) => (
        <li>
          <a href={`/${item.categorySlug}/${item.slug}/`} class="wc-latest-link">
            <span class="wc-latest-title">{item.title}</span>
            <span class="wc-latest-date">{formatDate(item.date)}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Center: Featured -->
  <div class="wc-featured">
    <a href={featuredHref} class="wc-featured-image-link">
      <img
        src={featured.heroImage}
        alt={featured.heroAlt}
        width="700"
        height="394"
        class="wc-featured-image"
      />
    </a>
    <div class="wc-featured-body">
      <h2 class="wc-featured-title">
        <a href={featuredHref}>{featured.title}</a>
      </h2>
      {featured.author && (
        <p class="wc-featured-byline">by {featured.author}</p>
      )}
      {featured.description && (
        <p class="wc-featured-excerpt">{featured.description}</p>
      )}
    </div>
  </div>

  <!-- Right: Deals / Picks -->
  <div class="wc-deals">
    <h2 class="wc-deals-heading">Top picks</h2>
    <p class="wc-deals-desc">Our editors' current favorites</p>
    <ul class="wc-deals-list">
      {deals.map((item) => (
        <li class="wc-deal-item">
          <a href={`/${item.categorySlug}/${item.slug}/`} class="wc-deal-link">
            <img
              src={item.heroImage}
              alt={item.heroAlt}
              width="80"
              height="80"
              loading="lazy"
              class="wc-deal-image"
            />
            <span class="wc-deal-title">{item.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .wc-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    padding: var(--space-xl) 0;
  }

  /* The Latest column */
  .wc-latest-heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 3px solid var(--color-text);
  }

  .wc-latest-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .wc-latest-list li {
    border-bottom: 1px solid var(--color-divider);
  }

  .wc-latest-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-sm) 0;
    text-decoration: none;
  }

  .wc-latest-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .wc-latest-link:hover .wc-latest-title {
    color: var(--color-text-muted);
  }

  .wc-latest-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* Featured center */
  .wc-featured {
    border-top: 4px solid var(--color-text);
    padding-top: var(--space-md);
  }

  .wc-featured-image-link {
    display: block;
    margin-bottom: var(--space-md);
  }

  .wc-featured-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--card-radius);
  }

  .wc-featured-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 var(--space-sm);
  }

  .wc-featured-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .wc-featured-title a:hover {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .wc-featured-byline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .wc-featured-excerpt {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Deals/Picks sidebar */
  .wc-deals-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 var(--space-xs);
    padding-bottom: var(--space-sm);
    border-bottom: 3px solid var(--color-text);
  }

  .wc-deals-desc {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .wc-deals-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .wc-deal-link {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    text-decoration: none;
  }

  .wc-deal-image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--card-radius);
    flex-shrink: 0;
  }

  .wc-deal-title {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .wc-deal-link:hover .wc-deal-title {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (min-width: 769px) {
    .wc-hero {
      grid-template-columns: 1fr 2fr;
      gap: var(--space-2xl);
    }

    .wc-deals {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1025px) {
    .wc-hero {
      grid-template-columns: 200px 1fr 240px;
    }

    .wc-featured-title {
      font-size: 2.5rem;
    }

    .wc-deals {
      grid-column: auto;
    }
  }
</style>
