---
interface Props {
  title: string;
  slug: string;
  category: string;
  categorySlug: string;
  heroImage: string;
  heroAlt: string;
  description?: string;
  date?: Date;
  readingTime?: number;
  variant?: 'default' | 'compact';
}

const {
  title,
  slug,
  category,
  categorySlug,
  heroImage,
  heroAlt,
  description,
  date,
  readingTime,
  variant = 'default',
} = Astro.props;

const href = `/${categorySlug}/${slug}/`;
const formattedDate = date ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(date) : '';
---

<article class:list={['article-card', variant]}>
  <a href={href} class="card-image-link">
    <img
      src={heroImage}
      alt={heroAlt}
      width="400"
      height="225"
      loading="lazy"
      class="card-image"
    />
  </a>
  <div class="card-body">
    <a href={`/${categorySlug}/`} class="category-label">{category}</a>
    <h3 class="card-title">
      <a href={href}>{title}</a>
    </h3>
    {variant === 'default' && description && (
      <p class="card-excerpt">{description}</p>
    )}
    {(formattedDate || readingTime) && (
      <div class="card-meta">
        {formattedDate && <span>{formattedDate}</span>}
        {formattedDate && readingTime && <span>&bull;</span>}
        {readingTime && <span>{readingTime} min read</span>}
      </div>
    )}
  </div>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
  }

  .article-card.compact {
    flex-direction: row;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .card-image-link {
    display: block;
    overflow: hidden;
    border-radius: var(--card-radius);
    flex-shrink: 0;
    box-shadow: var(--card-shadow);
  }

  .card-image {
    width: 100%;
    height: auto;
    aspect-ratio: var(--card-image-ratio);
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card-image-link:hover .card-image {
    transform: var(--card-hover-transform);
  }

  .compact .card-image-link {
    width: 100px;
    border-radius: 0.375rem;
  }

  .compact .card-image {
    width: 100px;
    height: 100px;
    aspect-ratio: 1;
  }

  .card-body {
    padding-top: var(--space-sm);
  }

  .compact .card-body {
    padding-top: 0;
    flex: 1;
  }

  .category-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    text-decoration: none;
    margin-bottom: var(--space-xs);
  }

  .category-label:hover {
    color: var(--color-primary-dark);
    text-decoration: none;
  }

  .card-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 var(--space-xs);
  }

  .article-card:not(.compact) .card-title {
    font-size: 1.125rem;
  }

  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 var(--space-xs);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 374px) {
    .compact .card-image-link {
      width: 70px;
    }

    .compact .card-image {
      width: 70px;
      height: 70px;
    }
  }
</style>
