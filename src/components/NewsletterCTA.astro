---
/**
 * Newsletter signup CTA for article sidebar.
 * Teal "Join Now" button, matching Healthline screenshot 04.
 */
import { siteConfig } from '../../site.config';
---

<aside class="newsletter-cta">
  <p class="newsletter-label">{siteConfig.name} Newsletter</p>
  <h3>Get evidence-based health insights</h3>
  <p class="newsletter-desc">Expert guidance on hair health, nutrition, and wellness delivered to your inbox weekly.</p>
  <form class="newsletter-form">
    <input type="email" placeholder="Enter your email" required aria-label="Email address" />
    <button type="submit">Join Now</button>
  </form>
  <p class="form-status" aria-live="polite"></p>
  <p class="privacy-note">Your <a href="/privacy/">privacy</a> is important to us</p>
</aside>

<style>
  .newsletter-cta {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: var(--space-xl);
  }

  .newsletter-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  h3 {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 var(--space-sm);
  }

  .newsletter-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-md);
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .newsletter-form input {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-body);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    outline: none;
    width: 100%;
  }

  .newsletter-form input:focus {
    border-color: var(--color-primary);
  }

  .newsletter-form button {
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-weight: 700;
    font-family: var(--font-body);
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .newsletter-form button:hover {
    background: var(--color-primary-dark);
  }

  .privacy-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  .privacy-note a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .form-status {
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
    margin-bottom: 0;
    line-height: 1.4;
  }

  .form-status:empty {
    display: none;
  }

  .form-status.success {
    color: var(--color-primary);
  }

  .form-status.error {
    color: #dc2626;
  }

  .newsletter-form button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>

<script>
  document.querySelectorAll('.newsletter-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]') as HTMLInputElement;
      const button = form.querySelector('button') as HTMLButtonElement;
      const status = form.parentElement?.querySelector('.form-status') as HTMLParagraphElement;
      if (!input || !button || !status) return;

      const email = input.value.trim();
      if (!email) return;

      button.disabled = true;
      button.textContent = 'Subscribing...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json();

        if (data.success) {
          status.textContent = data.message;
          status.classList.add('success');
          input.value = '';
        } else {
          status.textContent = data.error || 'Something went wrong. Please try again.';
          status.classList.add('error');
        }
      } catch {
        status.textContent = 'Network error. Please try again.';
        status.classList.add('error');
      } finally {
        button.disabled = false;
        button.textContent = 'Join Now';
      }
    });
  });
</script>
